NODE_ENV="development"
PORT=5000

DATABASE_URL= Your Db URL

BETTER_AUTH_SECRET= Your Better Auth Secret
BETTER_AUTH_URL= Base URL of your Better Auth Server (e.g., http://localhost:5000)

ACCESS_TOKEN_SECRET= Your Access Token Secret
REFRESH_TOKEN_SECRET= Your Refresh Token Secret
ACCESS_TOKEN_EXPIRES_IN= Your Access Token Expiry Time
REFRESH_TOKEN_EXPIRES_IN= Your Refresh Token Expiry Time
BETTER_AUTH_SESSION_EXPIRES_IN= Your Better Auth Session Expiry Time
BETTER_AUTH_SESSION_UPDATE_AGE= Your Better Auth Session Update Age